generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  inPrice     Float
  inStock     Int
  unit        String
}

model Language {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  en        String
  sw        String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
